page {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica,
    'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', Arial, sans-serif;
  font-size: 16px;
  line-height: 1.6;
  color: #5D5D5D;
  background: #F7F6F4;
  box-sizing: border-box;
  padding: 0;
  margin: 0;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

.card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 8rpx;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.04);
  padding: 48rpx;
  margin-bottom: 32rpx;
  box-sizing: border-box;
  border: 1rpx solid #E8E5E0;
}

.btn {
  width: 80%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #A8A196;
  color: #FFFFFF;
  border-radius: 4rpx;
  font-size: 30rpx;
  margin: 24rpx 0;
  border: none;
  transition: opacity 0.2s ease;
  font-weight: 400;
  letter-spacing: 2rpx;
}

.btn:active {
  opacity: 0.8;
}

.btn-secondary {
  background: #B5B0A8;
}

.btn-test {
  background: #C2B6B0;
  color: #FFFFFF;
}

.btn-special {
  background: transparent;
  color: #8B8680;
  border: 1rpx solid #D4D0CA;
}

.btn-special:active {
  background: #F7F6F4;
  color: #8B8680;
}

.btn-disabled {
  background: #E8E5E0;
  color: #C4C0BA;
  cursor: not-allowed;
}

.btn-disabled:active {
  opacity: 1;
}

.input-group {
  width: 100%;
  margin-bottom: 32rpx;
}

.input-label {
  font-size: 26rpx;
  color: #8B8680;
  margin-bottom: 16rpx;
  font-weight: 400;
  letter-spacing: 1rpx;
}

.input {
  width: 100%;
  height: 96rpx;
  border: 1rpx solid #D4D0CA;
  border-radius: 4rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  background: #FFFFFF;
  transition: border-color 0.2s ease;
  color: #5D5D5D;
}

.input:focus {
  border-color: #A8A196;
}

.title {
  font-size: 40rpx;
  font-weight: 300;
  text-align: center;
  margin-bottom: 48rpx;
  color: #5D5D5D;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 32rpx;
  font-weight: 400;
  margin-bottom: 24rpx;
  color: #6B6660;
  letter-spacing: 2rpx;
}

.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  border-radius: 4rpx;
  font-size: 24rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid #E8E5E0;
}

.room-info {
  display: flex;
  flex-direction: column;
  font-weight: 400;
  color: #8B8680;
}

.network-info {
  display: flex;
  align-items: center;
  font-weight: 400;
  color: #8B8680;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.dot-connected {
  background-color: #A8B5A0;
}

.dot-disconnected {
  background-color: #D4A5A5;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-center {
  justify-content: center;
}

.flex-between {
  justify-content: space-between;
}

.text-center {
  text-align: center;
}

.mt-20 {
  margin-top: 20rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.tacit-progress {
  width: 100%;
  height: 4rpx;
  background: #E8E5E0;
  border-radius: 0;
  overflow: hidden;
  margin: 24rpx 0;
}

.tacit-bar {
  height: 100%;
  background: #A8A196;
  transition: width 0.6s ease;
  border-radius: 0;
}

.option-btn {
  width: 100%;
  height: 104rpx;
  line-height: 104rpx;
  text-align: center;
  background: #FFFFFF;
  border: 1rpx solid #D4D0CA;
  color: #6B6660;
  border-radius: 4rpx;
  font-size: 30rpx;
  margin: 16rpx 0;
  transition: opacity 0.2s ease;
  font-weight: 400;
  letter-spacing: 1rpx;
}

.option-btn:active {
  opacity: 0.8;
}

.option-btn-selected {
  background: #A8A196;
  color: #FFFFFF;
  border-color: #A8A196;
}

/* 测试模式相关样式 */
.test-mode-indicator {
  background: #C2B6B0;
  color: #FFFFFF;
  padding: 20rpx 40rpx;
  border-radius: 4rpx;
  margin: 24rpx 0;
  text-align: center;
  font-size: 26rpx;
  font-weight: 400;
  letter-spacing: 2rpx;
}

.test-info {
  background: #F7F6F4;
  border-radius: 4rpx;
  padding: 24rpx;
  margin: 24rpx 0;
  border: 1rpx solid #E8E5E0;
}

.test-status {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #8B8680;
  font-weight: 400;
}

.debug-info {
  background: #F7F6F4;
  padding: 24rpx;
  border-radius: 4rpx;
  margin: 24rpx 0;
  font-size: 22rpx;
  color: #8B8680;
  border: 1rpx solid #E8E5E0;
}

.debug-btn {
  background: #B5B0A8;
  color: #FFFFFF;
  border: none;
  padding: 16rpx 32rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
  margin-top: 16rpx;
  font-weight: 400;
  letter-spacing: 1rpx;
}

.debug-btn:active {
  opacity: 0.8;
}

.battle-card {
  position: relative;
  background: #FFFFFF;
  border-radius: 4rpx;
  border: 1rpx solid #E8E5E0;
  overflow: hidden;
}

.vs-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 40rpx 0;
}

.noun-card {
  flex: 1;
  background: #FFFFFF;
  border: 1rpx solid #D4D0CA;
  border-radius: 4rpx;
  padding: 40rpx 24rpx;
  margin: 0 12rpx;
  text-align: center;
  cursor: pointer;
  transition: opacity 0.2s ease;
}

.noun-card:active {
  opacity: 0.8;
}

.noun-card.selected {
  background: #A8A196;
  border-color: #A8A196;
  color: #FFFFFF;
}

.noun-name {
  font-size: 32rpx;
  font-weight: 400;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.noun-category {
  font-size: 22rpx;
  opacity: 0.7;
  letter-spacing: 1rpx;
}

.vs-text {
  font-size: 32rpx;
  font-weight: 300;
  color: #B5B0A8;
  margin: 0 24rpx;
}

.battle-instruction {
  text-align: center;
  font-size: 26rpx;
  color: #8B8680;
  margin-top: 32rpx;
  font-weight: 400;
  letter-spacing: 1rpx;
}

.loading-container {
  text-align: center;
  padding: 96rpx 0;
  background: #FFFFFF;
  border-radius: 4rpx;
  margin: 24rpx;
  border: 1rpx solid #E8E5E0;
}

.loading-text {
  font-size: 30rpx;
  color: #8B8680;
  margin-bottom: 40rpx;
  font-weight: 400;
  letter-spacing: 2rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 2rpx solid #E8E5E0;
  border-top: 2rpx solid #A8A196;
  border-radius: 50%;
  margin: 24rpx auto;
}


.loading-tips {
  font-size: 24rpx;
  color: #B5B0A8;
  margin: 24rpx 0;
  letter-spacing: 1rpx;
}

.reload-btn {
  background: #A8A196;
  color: #FFFFFF;
  border: none;
  padding: 20rpx 40rpx;
  border-radius: 4rpx;
  font-size: 26rpx;
  transition: opacity 0.2s ease;
  font-weight: 400;
  letter-spacing: 2rpx;
}

.reload-btn:active {
  opacity: 0.8;
}

.waiting-message {
  text-align: center;
  padding: 32rpx;
  background: #F7F6F4;
  border-radius: 4rpx;
  margin: 24rpx 0;
  font-size: 26rpx;
  color: #8B8680;
  font-weight: 400;
  letter-spacing: 1rpx;
  border: 1rpx solid #E8E5E0;
}

.result-card {
  text-align: center;
  background: #FFFFFF;
  border-radius: 4rpx;
  padding: 48rpx;
  border: 1rpx solid #E8E5E0;
}

.result-title {
  font-size: 32rpx;
  font-weight: 400;
  margin-bottom: 32rpx;
  color: #5D5D5D;
  letter-spacing: 2rpx;
}

.champion-card {
  background: #F7F6F4;
  border-radius: 4rpx;
  padding: 40rpx;
  margin: 32rpx 0;
  border: 1rpx solid #D4D0CA;
}

.champion-name {
  font-size: 36rpx;
  font-weight: 400;
  color: #5D5D5D;
  margin-bottom: 12rpx;
  letter-spacing: 3rpx;
}

.champion-category {
  font-size: 26rpx;
  color: #8B8680;
  letter-spacing: 1rpx;
}

.eliminated-title {
  font-size: 28rpx;
  font-weight: 400;
  margin: 40rpx 0 24rpx 0;
  color: #6B6660;
  letter-spacing: 2rpx;
}

.eliminated-list {
  max-height: 320rpx;
  overflow-y: auto;
  background: #F7F6F4;
  border-radius: 4rpx;
  padding: 24rpx;
  border: 1rpx solid #E8E5E0;
}

.eliminated-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid #E8E5E0;
  font-size: 26rpx;
  color: #6B6660;
}

.eliminated-item:last-child {
  border-bottom: none;
}

.eliminated-category {
  color: #B5B0A8;
  letter-spacing: 1rpx;
}

.battle-progress {
  width: 100%;
  height: 4rpx;
  background: #E8E5E0;
  border-radius: 0;
  overflow: hidden;
  margin: 24rpx 0;
}

.battle-bar {
  height: 100%;
  background: #A8A196;
  transition: width 0.6s ease;
  border-radius: 0;
}

.battle-number {
  text-align: center;
  font-size: 24rpx;
  color: #8B8680;
  font-weight: 400;
  letter-spacing: 1rpx;
}