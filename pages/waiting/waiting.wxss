.player-list {
  padding: 20rpx 0;
}

.player-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #E8E5E0;
}

.player-item:last-child {
  border-bottom: none;
}

.player-item.waiting {
  opacity: 0.5;
}

.player-name {
  font-size: 30rpx;
  color: #5D5D5D;
}

.player-status {
  font-size: 24rpx;
  color: #8B8680;
  padding: 8rpx 16rpx;
  background: #F7F6F4;
  border-radius: 4rpx;
}

.countdown-container {
  text-align: center;
  padding: 60rpx 0;
}

.countdown-text {
  font-size: 30rpx;
  color: #6B6660;
  margin-bottom: 24rpx;
}

.countdown-number {
  font-size: 72rpx;
  font-weight: 300;
  color: #A8A196;
}