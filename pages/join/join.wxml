<view class="container">
  <view class="title">加入房间</view>
  
  <view class="card">
    <view class="input-group">
      <view class="input-label">输入6位房间号</view>
      <input 
        class="input room-input" 
        type="number"
        placeholder="000000" 
        maxlength="6"
        value="{{roomId}}"
        bindinput="onRoomIdInput"
      />
    </view>
  </view>

  <button class="btn {{isJoining ? 'btn-disabled' : ''}}" 
          bindtap="joinRoom" 
          disabled="{{isJoining}}">
    {{isJoining ? '加入中...' : '加入房间'}}
  </button>
  
  <button class="btn btn-secondary" bindtap="backToHome">返回首页</button>
  <view class="ai-caption">本游戏包含AI测试功能，AI选择结果由人工智能生成</view>
</view>