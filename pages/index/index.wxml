<view class="container">
  <view class="title">默契小游戏</view>
  
  <view class="status-bar">
    <view class="network-info">
      <view class="dot {{connectionStatus === '已连接' ? 'dot-connected' : 'dot-disconnected'}}"></view>
      <text>{{connectionStatus}}</text>
    </view>
  </view>

  <view class="card">
    <view class="input-group">
      <view class="input-label">输入你的昵称</view>
      <input 
        class="input" 
        placeholder="最多10个字符" 
        maxlength="10"
        value="{{nickname}}"
        bindinput="onNicknameInput"
      />
    </view>
  </view>

  <button class="btn" bindtap="createRoom">创建房间</button>
  <button class="btn btn-secondary" bindtap="joinRoom">加入房间</button>
  <button class="btn btn-theme" bindtap="enterThemeSelection">自选主题</button>
  
  <view class="version-info">v2.5.0 - 完整功能版</view>

  <!-- Debug log panel when connection fails -->
  <view class="debug-overlay" wx:if="{{showDebugLog}}" bindtap="hideDebugLog">
    <view class="debug-panel" catchtap="">
      <view class="debug-header">
        <text class="debug-title">连接诊断日志</text>
        <text class="debug-close" bindtap="hideDebugLog">✕</text>
      </view>
      <scroll-view class="debug-content" scroll-y>
        <text class="debug-text" selectable>{{debugLogText}}</text>
      </scroll-view>
      <view class="debug-actions">
        <button class="debug-btn debug-btn-copy" size="mini" bindtap="copyDebugLog">复制日志</button>
        <button class="debug-btn debug-btn-retry" size="mini" bindtap="retryConnection">重试连接</button>
      </view>
    </view>
  </view>
</view>