.title {
  font-size: 48rpx;
  font-weight: 300;
  margin-bottom: 60rpx;
  letter-spacing: 6rpx;
}

.switch-group {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 30rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
}

.switch-label {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.switch-label text:first-child {
  font-size: 30rpx;
  font-weight: 500;
}

.switch-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.version-info {
  position: fixed;
  bottom: 30rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 22rpx;
  color: #B8B1A6;
  opacity: 0.8;
  letter-spacing: 1rpx;
}