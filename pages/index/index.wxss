.title {
  font-size: 48rpx;
  font-weight: 300;
  margin-bottom: 60rpx;
  letter-spacing: 6rpx;
}

.version-info {
  position: fixed;
  bottom: 50rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 22rpx;
  color: #B8B1A6;
  opacity: 0.8;
  letter-spacing: 1rpx;
}

/* Debug log panel */
.debug-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.debug-panel {
  width: 85%;
  max-height: 70vh;
  background: #1e1e1e;
  border-radius: 20rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.debug-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #333;
}

.debug-title {
  font-size: 30rpx;
  color: #ff6b6b;
  font-weight: 600;
}

.debug-close {
  font-size: 36rpx;
  color: #888;
  padding: 0 10rpx;
}

.debug-content {
  max-height: 50vh;
  padding: 20rpx 30rpx;
}

.debug-text {
  font-size: 22rpx;
  color: #d4d4d4;
  font-family: monospace;
  line-height: 1.6;
  word-break: break-all;
}

.debug-actions {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #333;
  justify-content: center;
}

.debug-btn {
  font-size: 24rpx !important;
  border-radius: 12rpx !important;
  padding: 0 30rpx !important;
}

.debug-btn-copy {
  background: #4a9eff !important;
  color: #fff !important;
}

.debug-btn-retry {
  background: #52c41a !important;
  color: #fff !important;
}