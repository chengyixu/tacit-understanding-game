<view class="container">
  <view class="title">专项挑战</view>
  
  <view class="subtitle text-center">选择一个类别开始挑战</view>
  
  <view class="category-grid">
    <view wx:for="{{categories}}" 
          wx:key="id" 
          class="category-item {{selectedCategory.id === item.id ? 'selected' : ''}}"
          data-category="{{item}}"
          bindtap="selectCategory">
      <view class="category-icon">{{item.icon}}</view>
      <view class="category-name">{{item.name}}</view>
    </view>
  </view>

  <button class="btn btn-secondary" bindtap="backToHome">返回首页</button>
</view>