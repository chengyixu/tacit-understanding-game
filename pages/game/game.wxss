/* Existing styles */
.battle-container {
  width: 100%;
  padding: 20rpx;
  height: 100%;
  display: flex;
  flex-direction: column;
}

.player-info {
  font-size: 24rpx;
  color: #8B8680;
}

.history-container {
  width: 100%;
  margin-top: 40rpx;
  padding: 0 40rpx;
}

.loading-spinner {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.ai-caption {
  position: fixed;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 20rpx;
  color: rgba(184, 177, 166, 0.6);
  letter-spacing: 1rpx;
}

/* New Tinder-style swipe UI */
.swipe-instructions {
  text-align: center;
  margin-bottom: 30rpx;
}

.instruction-text {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.tinder-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  padding: 40rpx 30rpx;
}

.swipe-area {
  width: 100%;
  max-width: 700rpx;
  height: 800rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-display {
  width: 100%;
  height: 600rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: transform 0.1s ease-out;
  will-change: transform;
}

.option-card {
  width: 300rpx;
  height: 400rpx;
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.3s ease;
}

.option-card.highlighting {
  transform: scale(1.05);
  box-shadow: 0 15rpx 60rpx rgba(0, 0, 0, 0.2);
  border: 4rpx solid #4CAF50;
}

.option-a {
  margin-right: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.option-b {
  margin-left: 20rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.option-indicator {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.option-name {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  text-align: center;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.option-category {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
}

.vs-divider {
  position: absolute;
  width: 80rpx;
  height: 80rpx;
  background: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  z-index: 10;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.selection-overlay {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  padding: 20rpx 40rpx;
  background: rgba(0, 0, 0, 0.8);
  border-radius: 40rpx;
  transition: opacity 0.2s ease;
  pointer-events: none;
  z-index: 20;
}

.selection-overlay text {
  color: white;
  font-size: 36rpx;
  font-weight: bold;
}

.selection-overlay.left {
  background: linear-gradient(90deg, #667eea, #764ba2);
}

.selection-overlay.right {
  background: linear-gradient(90deg, #f093fb, #f5576c);
}

/* Quick tap buttons */
.tap-buttons {
  display: flex;
  justify-content: center;
  gap: 100rpx;
  margin-top: 40rpx;
}

.tap-btn {
  width: 100rpx;
  height: 100rpx;
  background: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  transition: all 0.3s ease;
}

.tap-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

/* Waiting message */
.waiting-message {
  position: absolute;
  bottom: 100rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.7);
  color: white;
  padding: 20rpx 40rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
}

/* Status bar styles */
.status-bar {
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-bottom: 1px solid #eee;
}

.room-info {
  font-size: 28rpx;
  color: #666;
}

/* Progress bar */
.battle-progress {
  height: 8rpx;
  background: #f0f0f0;
  position: relative;
  overflow: hidden;
}

.battle-bar {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #f093fb);
  transition: width 0.5s ease;
}

.battle-number {
  text-align: center;
  padding: 20rpx;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}