.battle-container {
  width: 100%;
  padding: 20rpx;
}

.player-info {
  font-size: 24rpx;
  color: #8B8680;
}

.history-container {
  width: 100%;
  margin-top: 40rpx;
  padding: 0 40rpx;
}

.loading-spinner {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}.ai-caption {
  position: fixed;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 20rpx;
  color: rgba(184, 177, 166, 0.6);
  letter-spacing: 1rpx;
}
