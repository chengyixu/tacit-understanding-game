.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #F7F6F4;
}

.status-bar {
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #FFFFFF;
  border-bottom: 1rpx solid #E8E5E0;
}

.room-info {
  font-size: 28rpx;
  color: #6B6660;
}

.player-info {
  font-size: 24rpx;
  color: #8B8680;
}

.battle-progress {
  height: 6rpx;
  background: #E8E5E0;
  position: relative;
  overflow: hidden;
}

.battle-bar {
  height: 100%;
  background: #A8A196;
  transition: width 0.35s ease;
}

.battle-number {
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #6B6660;
  font-weight: 400;
  letter-spacing: 2rpx;
}

.battle-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx 120rpx;
}

.battle-options {
  width: 100%;
  max-width: 720rpx;
  display: flex;
  justify-content: space-between;
  align-items: stretch;
  gap: 24rpx;
  position: relative;
}

.option-card {
  flex: 1;
  min-height: 360rpx;
  border-radius: 8rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  background: #FFFFFF;
  border: 2rpx solid #E8E5E0;
  color: #5D5D5D;
  transition: all 0.25s ease;
}

.option-card.option-a {
  background: #FFFFFF;
}

.option-card.option-b {
  background: #FFFFFF;
}

.option-card.selected {
  transform: scale(1.03);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  border: 3rpx solid #A8A196;
  background: #3D3833;
  color: #F0E9E0;
}

.option-card:active {
  transform: scale(0.98);
}

.option-name {
  font-size: 36rpx;
  font-weight: 500;
  text-align: center;
  line-height: 1.4;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.option-category {
  font-size: 24rpx;
  opacity: 0.7;
  text-align: center;
  letter-spacing: 1rpx;
}

.vs-divider {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #F7F6F4;
  border: 2rpx solid #E8E5E0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #6B6660;
  letter-spacing: 2rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  align-self: center;
}

.waiting-message {
  margin-top: 40rpx;
  background: #F7F6F4;
  border: 1rpx solid #E8E5E0;
  color: #6B6660;
  padding: 24rpx 36rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  letter-spacing: 1rpx;
}

.loading-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: #8B8680;
}

.loading-text {
  margin-bottom: 20rpx;
  font-size: 28rpx;
  letter-spacing: 1rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 4rpx solid #E8E5E0;
  border-top-color: #A8A196;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.history-container {
  width: 100%;
  margin-top: 40rpx;
  padding: 0 40rpx;
}

.ai-caption {
  position: fixed;
  top: 140rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 10rpx 20rpx;
  background: rgba(255, 193, 7, 0.2);
  border: 1px solid rgba(255, 193, 7, 0.4);
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #ffeb3b;
  font-weight: 500;
  text-align: center;
  letter-spacing: 1rpx;
  z-index: 10;
}
