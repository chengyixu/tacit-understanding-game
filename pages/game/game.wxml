<view class="container">
  <view class="status-bar">
    <view class="room-info">
      <text>房间: {{roomId}}</text>
    </view>
    <view class="player-info">
      <text>{{playerInfo.nickname}} vs {{opponentInfo.nickname || 'AI'}}</text>
    </view>
  </view>

  <view class="battle-progress">
    <view class="battle-bar" style="width: {{roundProgress}}%"></view>
  </view>
  <view class="battle-number">第 {{currentBattle.round}}/{{totalRounds}} 轮</view>

  <view wx:if="{{currentBattle}}" class="battle-container">
    <!-- Swipe Instructions -->
    <view class="swipe-instructions">
      <text class="instruction-text">← 左滑选择A | 右滑选择B →</text>
    </view>
    
    <!-- Tinder-style card stack -->
    <view class="tinder-container">
      <!-- Swipe area with both cards -->
      <view class="swipe-area" 
            bindtouchstart="onTouchStart"
            bindtouchmove="onTouchMove" 
            bindtouchend="onTouchEnd"
            bindtouchcancel="onTouchEnd">
        
        <!-- Central card stack that shows both options -->
        <view class="card-display" 
              style="transform: translateX({{swipeX}}px) rotate({{swipeRotation}}deg)">
          
          <!-- Option A (Left) -->
          <view class="option-card option-a {{swipeDirection === 'left' ? 'highlighting' : ''}}">
            <view class="option-indicator">A</view>
            <view class="option-name">{{currentBattle.noun1.name}}</view>
            <view class="option-category">{{currentBattle.noun1.category}}</view>
          </view>
          
          <!-- VS Divider -->
          <view class="vs-divider">
            <text>VS</text>
          </view>
          
          <!-- Option B (Right) -->
          <view class="option-card option-b {{swipeDirection === 'right' ? 'highlighting' : ''}}">
            <view class="option-indicator">B</view>
            <view class="option-name">{{currentBattle.noun2.name}}</view>
            <view class="option-category">{{currentBattle.noun2.category}}</view>
          </view>
        </view>
        
        <!-- Selection overlay -->
        <view class="selection-overlay {{swipeDirection}}" 
              style="opacity: {{overlayOpacity}}">
          <text wx:if="{{swipeDirection === 'left'}}">← 选择 A</text>
          <text wx:elif="{{swipeDirection === 'right'}}">选择 B →</text>
        </view>
      </view>
      
      <!-- Quick tap buttons -->
      <view class="tap-buttons">
        <view class="tap-btn" bindtap="quickSelectA">
          <text>A</text>
        </view>
        <view class="tap-btn" bindtap="quickSelectB">
          <text>B</text>
        </view>
      </view>
    </view>

    <view wx:if="{{waitingForOpponent && selectedNounId}}" class="waiting-message">
      等待对手选择中...
    </view>
  </view>

  <view wx:else class="loading-container">
    <view class="loading-text">准备下一轮...</view>
    <view class="loading-spinner"></view>
  </view>

  <view wx:if="{{battleHistory.length > 0}}" class="history-container">
    <view class="subtitle">淘汰记录</view>
    <view class="eliminated-list">
      <view wx:for="{{battleHistory}}" wx:key="round" class="eliminated-item">
        <text>第{{item.round}}轮</text>
        <text class="eliminated-category">{{item.loser.name}} 淘汰</text>
      </view>
    </view>
  </view>
  <view class="ai-caption">AI生成、人工智能生成</view>
</view>