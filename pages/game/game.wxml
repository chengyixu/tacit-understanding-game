<view class="container">
  <view class="status-bar">
    <view class="room-info">
      <text>房间: {{roomId}}</text>
    </view>
    <view class="player-info">
      <text>{{playerInfo.nickname}} vs {{opponentInfo.nickname}}</text>
    </view>
  </view>

  <view class="battle-progress">
    <view class="battle-bar" style="width: {{roundProgress}}%"></view>
  </view>
  <view class="battle-number">第 {{currentBattle.round}}/{{totalRounds}} 轮</view>

  <view wx:if="{{currentBattle}}" class="battle-container">
    <view class="battle-instruction">选择你更喜欢的一个</view>
    
    <view class="vs-container">
      <view class="noun-card {{selectedNounId == currentBattle.noun1.id ? 'selected' : ''}}"
            data-id="{{currentBattle.noun1.id}}"
            bindtap="selectNoun">
        <view class="noun-name">{{currentBattle.noun1.name}}</view>
        <view class="noun-category">{{currentBattle.noun1.category}}</view>
      </view>
      
      <view class="vs-text">VS</view>
      
      <view class="noun-card {{selectedNounId == currentBattle.noun2.id ? 'selected' : ''}}"
            data-id="{{currentBattle.noun2.id}}"
            bindtap="selectNoun">
        <view class="noun-name">{{currentBattle.noun2.name}}</view>
        <view class="noun-category">{{currentBattle.noun2.category}}</view>
      </view>
    </view>

    <view wx:if="{{waitingForOpponent && selectedNounId}}" class="waiting-message">
      等待对手选择中...
    </view>
  </view>

  <view wx:else class="loading-container">
    <view class="loading-text">准备下一轮...</view>
    <view class="loading-spinner"></view>
  </view>

  <view wx:if="{{battleHistory.length > 0}}" class="history-container">
    <view class="subtitle">淘汰记录</view>
    <view class="eliminated-list">
      <view wx:for="{{battleHistory}}" wx:key="round" class="eliminated-item">
        <text>第{{item.round}}轮</text>
        <text class="eliminated-category">{{item.loser.name}} 淘汰</text>
      </view>
    </view>
  </view>
</view>