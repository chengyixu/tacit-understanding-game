.title {
  font-size: 48rpx;
  font-weight: 300;
  margin-bottom: 60rpx;
  letter-spacing: 6rpx;
  color: #5D5D5D;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  width: 100%;
  margin-bottom: 60rpx;
}

.category-item {
  width: 30%;
  height: 180rpx;
  background: #FFFFFF;
  border: 1rpx solid #E8E5E0;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  transition: all 0.2s ease;
}

.category-item:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.category-selected {
  background: #C5BAAF;
  border-color: #C5BAAF;
}

.category-selected .category-name {
  color: #FFFFFF;
}

.category-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.category-name {
  font-size: 24rpx;
  color: #6B6660;
  font-weight: 400;
  letter-spacing: 1rpx;
}