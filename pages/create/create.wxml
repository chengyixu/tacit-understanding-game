<view class="container">
  <view class="title">创建房间</view>
  
  <view class="card compact-card">
    <view class="subtitle">游戏模式</view>
    <view class="mode-selector">
      <view class="mode-option {{!groupMode ? 'active' : ''}}" bindtap="toggleGroupMode" data-mode="false">
        <text class="mode-icon">👥</text>
        <text class="mode-name">双人对战</text>
        <text class="mode-desc">经典1v1默契测试</text>
      </view>
      <view class="mode-option disabled">
        <text class="mode-icon">👫👬👭</text>
        <text class="mode-name">多人派对</text>
        <text class="mode-desc">3-6人群体默契大比拼</text>
        <text class="mode-dev-tag">正在开发中</text>
      </view>
    </view>
    
    <view wx:if="{{groupMode}}" class="player-count-selector">
      <view class="count-options">
        <view wx:for="{{[3,4,5,6]}}" wx:key="*this" 
              class="count-option {{maxPlayers == item ? 'selected' : ''}}"
              bindtap="selectPlayerCount" data-count="{{item}}">
          {{item}}人
        </view>
      </view>
    </view>
  </view>
  
  <view class="card compact-card">
    <view class="subtitle">房间号</view>
    <view class="room-id-display-compact">
      <text class="room-id">{{roomId || '生成中...'}}</text>
    </view>
  </view>

  <view class="invite-section">
    <text class="invite-text-compact">分享房间号给朋友加入游戏<text wx:if="{{groupMode}}" class="group-note-inline">（需{{maxPlayers}}人）</text></text>
  </view>

  <button class="btn btn-primary" bindtap="enterWaitingRoom">进入等待室</button>
  <button class="btn btn-copy" bindtap="copyRoomId" disabled="{{!roomId}}">复制房间号</button>
  <button class="btn btn-secondary" bindtap="backToHome">返回首页</button>
  <view class="ai-caption" wx:if="{{testMode}}">AI测试模式已启用，包含人工智能生成内容</view>
</view>