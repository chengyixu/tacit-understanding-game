/* Mode Selector Styles */
.mode-selector {
  display: flex;
  gap: 20rpx;
  margin: 20rpx 0;
}

.mode-option {
  flex: 1;
  padding: 24rpx 16rpx;
  background: #F9F8F6;
  border: 2rpx solid #E8E5E0;
  border-radius: 12rpx;
  text-align: center;
  transition: all 0.3s;
  cursor: pointer;
}

.mode-option.active {
  background: #3D3833;
  border-color: #3D3833;
}

.mode-option .mode-icon {
  display: block;
  font-size: 36rpx;
  margin-bottom: 12rpx;
}

.mode-option .mode-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #6B6660;
  margin-bottom: 8rpx;
}

.mode-option.active .mode-name {
  color: #F0E9E0;
}

.mode-option .mode-desc {
  display: block;
  font-size: 22rpx;
  color: #A8A196;
}

.mode-option.active .mode-desc {
  color: #B8B1A6;
}

/* Player Count Selector */
.player-count-selector {
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #E8E5E0;
}

.count-options {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
}

.count-option {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  background: #F9F8F6;
  border: 2rpx solid #E8E5E0;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #6B6660;
  transition: all 0.3s;
}

.count-option.selected {
  background: #3D3833;
  border-color: #3D3833;
  color: #F0E9E0;
  font-weight: 500;
}

/* Room ID Display */
.room-id-display {
  text-align: center;
  padding: 40rpx 0;
  background: #F7F6F4;
  border-radius: 4rpx;
  margin: 24rpx 0;
}

.room-id {
  font-size: 48rpx;
  font-weight: 300;
  letter-spacing: 8rpx;
  color: #5D5D5D;
}

/* Invite Text */
.invite-text {
  font-size: 26rpx;
  color: #8B8680;
  line-height: 1.8;
  letter-spacing: 1rpx;
}

.group-note {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #A8A196;
  font-weight: 500;
}

.ai-caption {
  position: fixed;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 20rpx;
  color: rgba(184, 177, 166, 0.6);
  letter-spacing: 1rpx;
}