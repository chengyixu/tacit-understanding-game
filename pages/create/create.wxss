/* Compact Card */
.compact-card {
  padding: 32rpx !important;
  margin-bottom: 20rpx !important;
}

/* Mode Selector Styles */
.mode-selector {
  display: flex;
  gap: 16rpx;
  margin: 16rpx 0 0 0;
}

.mode-option {
  flex: 1;
  padding: 20rpx 12rpx;
  background: #F9F8F6;
  border: 2rpx solid #E8E5E0;
  border-radius: 8rpx;
  text-align: center;
  transition: all 0.3s;
  cursor: pointer;
}

.mode-option.active {
  background: #3D3833;
  border-color: #3D3833;
}

.mode-option .mode-icon {
  display: block;
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.mode-option .mode-name {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #6B6660;
  margin-bottom: 4rpx;
}

.mode-option.active .mode-name {
  color: #F0E9E0;
}

.mode-option .mode-desc {
  display: block;
  font-size: 20rpx;
  color: #A8A196;
}

.mode-option.active .mode-desc {
  color: #B8B1A6;
}

.mode-option.disabled {
  background: #F0EDE9;
  border-color: #E8E5E0;
  opacity: 0.5;
  cursor: not-allowed;
  position: relative;
}

.mode-option.disabled .mode-icon,
.mode-option.disabled .mode-name,
.mode-option.disabled .mode-desc {
  color: #B5B0A8;
}

.mode-dev-tag {
  display: block;
  font-size: 18rpx;
  color: #C4C0BA;
  margin-top: 6rpx;
  font-weight: 400;
  letter-spacing: 0.5rpx;
}

/* Player Count Selector */
.player-count-selector {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #E8E5E0;
}

.count-options {
  display: flex;
  gap: 12rpx;
  margin-top: 0;
}

.count-option {
  flex: 1;
  padding: 16rpx;
  text-align: center;
  background: #F9F8F6;
  border: 2rpx solid #E8E5E0;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #6B6660;
  transition: all 0.3s;
}

.count-option.selected {
  background: #3D3833;
  border-color: #3D3833;
  color: #F0E9E0;
  font-weight: 500;
}

/* Room ID Display - Compact */
.room-id-display-compact {
  text-align: center;
  padding: 24rpx 0;
  background: #F7F6F4;
  border-radius: 4rpx;
  margin: 16rpx 0 0 0;
}

.room-id {
  font-size: 44rpx;
  font-weight: 300;
  letter-spacing: 8rpx;
  color: #5D5D5D;
}

/* Invite Section - Compact */
.invite-section {
  width: 100%;
  text-align: center;
  margin: 12rpx 0;
}

.invite-text-compact {
  font-size: 24rpx;
  color: #A8A196;
  line-height: 1.6;
  letter-spacing: 0.5rpx;
}

.group-note-inline {
  font-size: 22rpx;
  color: #B5B0A8;
  margin-left: 8rpx;
}

/* Button Styles */
.btn-primary {
  background: #3D3833 !important;
  font-weight: 500;
}

.btn-copy {
  background: #C5BAAF !important;
  margin: 12rpx 0;
}

.ai-caption {
  margin-top: 30rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 193, 7, 0.2);
  border: 1px solid rgba(255, 193, 7, 0.4);
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #ffeb3b;
  font-weight: 500;
  text-align: center;
  letter-spacing: 1rpx;
}