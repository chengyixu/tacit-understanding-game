.tacit-container {
  margin-top: 40rpx;
}

.tacit-value {
  font-size: 64rpx;
  font-weight: 300;
  color: #A8A196;
  text-align: center;
  margin: 20rpx 0;
}

.tacit-level {
  font-size: 32rpx;
  color: #6B6660;
  text-align: center;
  margin-bottom: 24rpx;
  letter-spacing: 2rpx;
}

.players-summary {
  text-align: center;
  margin-top: 32rpx;
  font-size: 26rpx;
  color: #8B8680;
  letter-spacing: 1rpx;
}

/* 计算摘要样式 */
.calculation-summary {
  margin-top: 30rpx;
  padding: 20rpx;
  background: #F9F8F6;
  border-radius: 12rpx;
}

.calc-method {
  text-align: center;
  font-size: 24rpx;
  color: #A8A196;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.calc-formula {
  text-align: center;
  font-size: 30rpx;
  color: #6B6660;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.calc-stats {
  text-align: center;
  font-size: 26rpx;
  color: #8B8680;
  margin-bottom: 12rpx;
}

.calc-info {
  text-align: center;
  font-size: 24rpx;
  color: #A8A196;
  margin-bottom: 12rpx;
}

.calc-explanation {
  text-align: center;
  font-size: 22rpx;
  color: #B8B1A6;
  line-height: 1.6;
  padding: 0 20rpx;
  margin-top: 16rpx;
}

/* 详细对比样式 */
.detail-title {
  font-size: 32rpx;
  color: #6B6660;
  font-weight: 500;
  margin-bottom: 30rpx;
  text-align: center;
}

.detail-list {
  padding: 0 20rpx;
}

.detail-item {
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #E8E4DC;
}

.detail-item:last-child {
  border-bottom: none;
}

.round-number {
  font-size: 24rpx;
  color: #A8A196;
  margin-bottom: 16rpx;
  text-align: center;
}

.battle-info {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.player-battle {
  padding: 16rpx;
  background: #F9F8F6;
  border-radius: 8rpx;
}

.player-name {
  display: block;
  font-size: 24rpx;
  color: #8B8680;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.battle-text {
  display: block;
  font-size: 26rpx;
  color: #6B6660;
  margin-bottom: 8rpx;
}

.choice-result {
  display: block;
  font-size: 28rpx;
  color: #5B5650;
  font-weight: 500;
  margin-top: 8rpx;
}

/* Champions Display */
.champions-container {
  display: flex;
  justify-content: space-around;
  margin-top: 30rpx;
  gap: 30rpx;
}

.player-champion {
  flex: 1;
  text-align: center;
}

.player-label {
  font-size: 26rpx;
  color: #8B8680;
  margin-bottom: 16rpx;
}

.no-champion {
  font-size: 28rpx;
  color: #6B6660;
  padding: 20rpx;
  background: rgba(0,0,0,0.1);
  border-radius: 12rpx;
}

.btn-debug {
  background: #3A3830;
  color: #A8A196;
  font-size: 24rpx;
  padding: 16rpx 32rpx;
  margin-top: 20rpx;
}

/* Debug Panel Styles */
.debug-panel {
  margin-top: 40rpx;
  background: #2A2820;
  border-radius: 16rpx;
  padding: 20rpx;
  max-height: 600rpx;
}

.debug-title {
  font-size: 32rpx;
  color: #A8A196;
  font-weight: 500;
  margin-bottom: 20rpx;
  text-align: center;
}

.debug-scroll {
  max-height: 500rpx;
  background: #1E1C16;
  border-radius: 8rpx;
  padding: 16rpx;
}

.debug-entry {
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #3A3830;
}

.debug-entry:last-child {
  border-bottom: none;
}

.debug-time {
  color: #888;
  font-size: 22rpx;
  margin-right: 8rpx;
}

.debug-message {
  color: #F0E9E0;
  font-size: 24rpx;
  font-weight: 500;
}

.debug-data {
  margin-top: 8rpx;
  padding: 8rpx;
  background: #252218;
  border-radius: 4rpx;
  font-size: 20rpx;
  color: #B8B1A6;
  word-break: break-all;
  white-space: pre-wrap;
}

/* Famous Pairs Comparison Styles */
.famous-pairs-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.famous-pairs-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #3D3833;
}

.btn-toggle {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  background: #F3F2F0;
  border: none;
  border-radius: 20rpx;
  color: #6B6660;
}

.famous-pairs-intro {
  font-size: 26rpx;
  color: #8B8680;
  margin-bottom: 24rpx;
  text-align: center;
}

.famous-pair-item {
  padding: 24rpx;
  background: #F9F8F6;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.pair-names {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.pair-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #3D3833;
}

.pair-category {
  font-size: 24rpx;
  color: #A8A196;
  padding: 4rpx 12rpx;
  background: #EFEDE9;
  border-radius: 20rpx;
}

.pair-description {
  font-size: 24rpx;
  color: #8B8680;
  margin-bottom: 16rpx;
  font-style: italic;
}

.pair-score-comparison {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.pair-score {
  font-size: 28rpx;
  font-weight: 500;
  color: #6B6660;
}

.comparison-badge {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.badge-higher {
  background: #FFE5E5;
  color: #FF6B6B;
}

.badge-lower {
  background: #E5F5E5;
  color: #4CAF50;
}

.badge-equal {
  background: #FFF5E5;
  color: #FFA726;
}

.score-bar-container {
  position: relative;
  height: 60rpx;
}

.score-bar-bg {
  position: absolute;
  top: 20rpx;
  left: 0;
  right: 0;
  height: 20rpx;
  background: #EFEDE9;
  border-radius: 10rpx;
  overflow: hidden;
}

.score-bar-fill {
  height: 100%;
  background: linear-gradient(to right, #FFB6C1, #FF69B4);
  border-radius: 10rpx;
  transition: width 0.5s ease;
}

.your-score-marker {
  position: absolute;
  top: 0;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.your-score-marker::before {
  content: '▼';
  color: #FF1493;
  font-size: 20rpx;
}

.marker-text {
  font-size: 22rpx;
  color: #FF1493;
  font-weight: 500;
  margin-top: -4rpx;
}

.famous-pairs-summary {
  text-align: center;
  font-size: 26rpx;
  color: #8B8680;
  padding: 20rpx;
}

/* Group Mode Styles */
.group-tacit-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #3D3833;
  text-align: center;
  margin: 40rpx 0 20rpx;
}

.pairwise-scores {
  background: #F9F8F6;
  border-radius: 16rpx;
  padding: 20rpx;
  margin: 20rpx 0;
}

.score-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #E8E5E0;
}

.score-item:last-child {
  border-bottom: none;
}

.score-rank {
  font-size: 36rpx;
  font-weight: 300;
  color: #A8A196;
  width: 60rpx;
  text-align: center;
}

.score-info {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-left: 20rpx;
}

.score-player {
  font-size: 28rpx;
  font-weight: 500;
  color: #3D3833;
}

.score-value {
  font-size: 32rpx;
  font-weight: 500;
  color: #6B6660;
}

.score-level {
  font-size: 24rpx;
  color: #A8A196;
  padding: 6rpx 12rpx;
  background: #EFEDE9;
  border-radius: 20rpx;
}

.best-match-message {
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  color: #3D3833;
  padding: 30rpx;
  background: linear-gradient(135deg, #FFE5E5, #FFF5E5);
  border-radius: 16rpx;
  margin-top: 20rpx;
}.ai-caption {
  margin-top: 30rpx;
  margin-bottom: 20rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 193, 7, 0.2);
  border: 1px solid rgba(255, 193, 7, 0.4);
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #ffeb3b;
  font-weight: 500;
  text-align: center;
  letter-spacing: 1rpx;
}
