<view class="container">
  <view class="title">游戏结束</view>
  
  <!-- Group Mode Results -->
  <view wx:if="{{groupMode}}" class="result-card">
    <view class="result-title">多人派对结果</view>
    
    <view class="champion-card">
      <view class="champion-name">我的冠军词: {{myChampion.name}}</view>
      <view class="champion-category">{{myChampion.category}}</view>
    </view>
    
    <view class="group-tacit-title">默契度排行榜</view>
    <view class="pairwise-scores">
      <view wx:for="{{myPairwiseScores}}" wx:key="playerName" class="score-item">
        <view class="score-rank">#{{index + 1}}</view>
        <view class="score-info">
          <view class="score-player">{{item.playerName}}</view>
          <view class="score-value">{{item.tacitScore}}%</view>
          <view class="score-level">{{item.tacitLevel}}</view>
        </view>
      </view>
    </view>
    
    <view wx:if="{{myPairwiseScores[0]}}" class="best-match-message">
      🏆 你和 {{myPairwiseScores[0].playerName}} 最有默契！
    </view>
  </view>
  
  <!-- 2-Player Mode Results -->
  <view wx:else class="result-card">
    <view class="result-title">最终获胜词汇</view>
    
    <!-- Display both players' champions -->
    <view class="champions-container">
      <view class="player-champion">
        <view class="player-label">{{playerInfo.nickname}}的冠军词</view>
        <view wx:if="{{myChampion}}" class="champion-card">
          <view class="champion-name">{{myChampion.name}}</view>
          <view class="champion-category">{{myChampion.category}}</view>
        </view>
        <view wx:else class="no-champion">未获得冠军词</view>
      </view>
      
      <view class="player-champion">
        <view class="player-label">{{opponentInfo.nickname}}的冠军词</view>
        <view wx:if="{{opponentChampion}}" class="champion-card">
          <view class="champion-name">{{opponentChampion.name}}</view>
          <view class="champion-category">{{opponentChampion.category}}</view>
        </view>
        <view wx:else class="no-champion">未获得冠军词</view>
      </view>
    </view>
    
    <view class="tacit-container">
      <view class="result-title">默契值</view>
      <view class="tacit-value">{{tacitValue}}%</view>
      <view class="tacit-level">{{tacitLevel}}</view>
      
      <view class="tacit-progress">
        <view class="tacit-bar" style="width: {{tacitValue}}%"></view>
      </view>
      
      <!-- 计算步骤展示 -->
      <view class="calculation-summary">
        <view wx:if="{{calculationDetails && calculationDetails.explanation}}" class="calc-explanation">{{calculationDetails.explanation}}</view>
        <view wx:else class="calc-explanation">
          默契值由后台根据双方选择偏好自动计算
        </view>
      </view>
    </view>
    
    <view class="players-summary">
      <text>{{playerInfo.nickname}} & {{opponentInfo.nickname}}</text>
    </view>
  </view>

  <!-- 详细选择对比 -->
  <view wx:if="{{calculationDetails.choices && calculationDetails.choices.length > 0}}" class="card">
    <view class="detail-title">选择对比详情</view>
    <view class="detail-list">
      <view wx:for="{{calculationDetails.choices}}" wx:key="round" class="detail-item">
        <view class="round-number">第{{item.round}}轮</view>
        <view class="battle-info">
          <view class="player-battle">
            <text class="player-name">{{playerInfo.nickname}}</text>
            <text class="battle-text">{{item.player1_battle}}</text>
            <text class="choice-result">选择: {{item.player1_choice}}</text>
          </view>
          <view class="player-battle">
            <text class="player-name">{{opponentInfo.nickname}}</text>
            <text class="battle-text">{{item.player2_battle}}</text>
            <text class="choice-result">选择: {{item.player2_choice}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{eliminatedNouns.length > 0}}" class="card">
    <view class="eliminated-title">淘汰词汇</view>
    <view class="eliminated-list">
      <view wx:for="{{eliminatedNouns}}" wx:key="id" class="eliminated-item">
        <text>{{item.name}}</text>
        <text class="eliminated-category">{{item.category}}</text>
      </view>
    </view>
  </view>
  
  <!-- Famous Pairs Comparison -->
  <view class="card">
    <view class="famous-pairs-header">
      <view class="famous-pairs-title">📊 明星CP对比</view>
      <button class="btn-toggle" bindtap="toggleFamousPairs">
        {{showFamousPairs ? '收起' : '展开'}}
      </button>
    </view>
    
    <view wx:if="{{showFamousPairs}}" class="famous-pairs-list">
      <view class="famous-pairs-intro">看看你们和当红明星CP相比如何：</view>
      <view wx:for="{{famousPairs}}" wx:key="index" class="famous-pair-item">
        <view class="pair-names">
          <text class="pair-name">{{item.name1}} & {{item.name2}}</text>
          <text class="pair-category">{{item.category}}</text>
        </view>
        <view class="pair-description">{{item.description}}</view>
        <view class="pair-score-comparison">
          <view class="pair-score">默契度: {{item.tacitScore}}%</view>
          <view class="comparison-badge {{item.tacitScore > tacitValue ? 'badge-higher' : item.tacitScore < tacitValue ? 'badge-lower' : 'badge-equal'}}">
            {{item.comparison}}
          </view>
        </view>
        <view class="score-bar-container">
          <view class="score-bar-bg">
            <view class="score-bar-fill" style="width: {{item.tacitScore}}%"></view>
          </view>
          <view class="your-score-marker" style="left: {{tacitValue}}%">
            <text class="marker-text">你们</text>
          </view>
        </view>
      </view>
    </view>
    
    <view wx:else class="famous-pairs-summary">
      <text>与 {{famousPairs[0].name1}} & {{famousPairs[0].name2}} 最接近 ({{famousPairs[0].tacitScore}}%)</text>
    </view>
  </view>

  <button class="btn" bindtap="playAgain">再来一局</button>
  <button class="btn btn-special" bindtap="shareResult">生成证书并分享</button>
  <button class="btn btn-secondary" bindtap="backToHome">返回首页</button>
  
  <!-- Hidden canvas for certificate generation -->
  <canvas canvas-id="certificateCanvas" style="position: fixed; top: -9999px; width: 375px; height: 500px;"></canvas>
  <view class="ai-caption" wx:if="{{opponentInfo.nickname === 'AI测试员'}}">对手为AI，结果包含人工智能生成内容</view>
</view>
